# =============================================================================
# Frontend env (Vite)
# Variables prefixed with VITE_ are bundled into the client. Do NOT put secrets
# (API keys, credentials) here — they will be visible in the built JS.
# =============================================================================

# API base. Leave blank to use the Vite dev proxy (which forwards /api → :5000).
# In production set this to your backend origin, e.g. https://api.pashtohub.com/api
VITE_API_URL=

# Public site URL — used by the SEO component for canonical URLs / OG tags.
VITE_SITE_URL=https://pashtohub.com

# Admin URL prefix — keep in sync with the backend ADMIN_PATH env var so the
# robots.txt blocks the same path the React Router serves.
VITE_ADMIN_PATH=pashto-hub
