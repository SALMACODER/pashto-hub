# =============================================================================
# Server
# =============================================================================
NODE_ENV=development
PORT=5000

# =============================================================================
# MongoDB — replace with your Atlas URI or keep for local MongoDB
# =============================================================================
MONGO_URI=mongodb://localhost:27017/pashtohub

# =============================================================================
# Auth (JWT)
#   - Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   - JWT_SECRET           : signs the short-lived ACCESS token
#   - JWT_REFRESH_SECRET   : signs the long-lived REFRESH token (must differ from JWT_SECRET in prod)
#   - JWT_ACCESS_EXPIRE    : 15m recommended
#   - JWT_REFRESH_EXPIRE   : 7d recommended
# =============================================================================
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=change_this_to_a_DIFFERENT_long_random_string
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Optional — signs cookies (used by cookie-parser for tamper detection)
COOKIE_SECRET=another_long_random_string_for_cookies

# CSRF — protects state-changing requests when using cookie auth
CSRF_SECRET=yet_another_long_random_string_for_csrf

# =============================================================================
# CORS — your frontend origin
# =============================================================================
CLIENT_URL=http://localhost:5173

# =============================================================================
# Cloudinary — used for ALL media (images + PDFs).
# Find these at:  https://cloudinary.com/console (Account Details panel)
# Without these the /api/admin/uploads/* endpoints will return 503.
# =============================================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional override — defaults to "pashto-hub"
CLOUDINARY_BASE_FOLDER=pashto-hub

# =============================================================================
# Local upload storage (alternative to Cloudinary). Files saved here are
# served at /uploads/<bucket>/<filename> via express.static. The dir is
# auto-created on boot if missing. Defaults to <backend>/uploads.
# In production, point this at a persistent volume — most PaaS hosts wipe
# the project directory on each deploy.
# =============================================================================
UPLOAD_DIR=./uploads

# =============================================================================
# Admin URL prefix — used by the dynamic robots.txt to keep the admin URL
# out of search engine indexes. Must MATCH the frontend's VITE_ADMIN_PATH.
# =============================================================================
ADMIN_PATH=pashto-hub

# =============================================================================
# Optional: seed admin account
# =============================================================================
ADMIN_NAME=Admin
[email protected]
ADMIN_PASSWORD=Admin@123
